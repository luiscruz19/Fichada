MAILER_PORT=80
NODE_ENV=development
APP_NAME=Fichada
WEB_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
AUTH_BASIC_USER=mailer
AUTH_BASIC_PW=secret
SECRET_KEY=supersecret
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
# SMTP
MAILER_USER=tu@email.com
MAILER_PASSWORD=smtp_password
MAILER_SMTP_HOST=smtp.gmail.com
MAILER_SMTP_PORT=587
MAILER_SMTP_SECURE=false
# Identidad
MAILER_FROM_NAME=Fichada
MAILER_FROM_EMAIL=noreply@fichada.com
# Branding templates
PROJECT_LOGO_URL=http://localhost:3000/logo.png
PROJECT_WEB_URL=http://localhost:3000
PROJECT_SUPPORT_EMAIL=soporte@fichada.com
PROJECT_PHONE=+54 381 000-0000
BRAND_PRIMARY_COLOR=#6366F1
BRAND_ACCENT_COLOR=#4F46E5
# Redirect en desarrollo
MAILER_DEV_REDIRECT_EMAIL=
# Ventas / contacto
MAILER_SALES_EMAIL=ventas@fichada.com
MAILER_CONTACT_EMAIL=contacto@fichada.com
# Newsletter
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
MAILCHIMP_SERVER=us1
MAILERLITE_API_KEY=
AUTH_API_URL=http://fichada_auth
CONFIG_API_URL=
# DB EmailLog (opcional, MySQL compartido de /opt/shared)
DB_HOST_MAILER=mysql_db
DB_PORT_MAILER=3306
DB_USER_MAILER=root
# Lo completa `make env` leyendo /opt/shared/.env (no se commitea el secreto).
DB_ROOT_PASSWORD_MAILER=CHANGEME
DB_NAME_MAILER=FICHADA_MAILER
DB_DIALECT_MAILER=mysql
# Feature flags
ENABLE_TEMPLATES=false
ENABLE_MAILCHIMP=false
ENABLE_MAILERLITE=false
ENABLE_CONTACT=false
ENABLE_EMAIL_LOG=false
# DB Pool (solo si ENABLE_EMAIL_LOG=true)
DB_POOL_MAX=10
DB_POOL_MIN=2
