# ─── Servidor ────────────────────────────────────────────────────────────────
AUTH_PORT=80
NODE_ENV=development

# ─── Branding ─────────────────────────────────────────────────────────────────
APP_NAME=Fichada
WEB_URL=http://localhost:3000
LOGO_URL=http://localhost:3000/logo.png

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Falls back to WEB_URL if not set.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Base de datos Auth ────────────────────────────────────────────────────────
DB_HOST_AUTH=mysql_db
DB_PORT_AUTH=3306
DB_USER_AUTH=root
# Lo completa `make env` leyendo /opt/shared/.env (no se commitea el secreto).
DB_ROOT_PASSWORD_AUTH=CHANGEME
DB_NAME_AUTH=FICHADA_AUTH
DB_DIALECT_AUTH=mysql

# When true, creates the database if it doesn't exist before connecting (MySQL only)
DB_AUTOCREATE=false

# ─── Auth interna (Basic Auth servicio↔servicio) ──────────────────────────────
AUTH_BASIC_USER=auth
AUTH_BASIC_PW=secret

# ─── JWT (compartido con el api de fichada, HS256) ─────────────────────────────
SECRET_KEY=supersecret
# Session timeout en ms. El mobile usa sesión larga; ajustá según política.
SESSION_TIMEOUT=28800000

# ─── Brute-force / lockout ────────────────────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5
LOGIN_BLOCK_WINDOW_MS=900000

# ─── Rate limit global ────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Mailer ───────────────────────────────────────────────────────────────────
MAILER_API_URL=http://fichada_mailer

# ─── Seed admin (optional) ────────────────────────────────────────────────────
ADMIN_EMAIL=admin@fichada.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NOMBRE=Administrador

# ─── Feature flags ────────────────────────────────────────────────────────────
AUTH_USE_JWT_LINKS=false

# DB Pool
DB_POOL_MAX=10
DB_POOL_MIN=2
