# Runtime del server de test. Copiar como `.env` en /opt/test/fichada (NO se versiona).
# Un solo .env compartido por los 4 servicios (las vars con prefijo no chocan; el
# AUTH_BASIC_USER del mailer se override en el compose).

# ─── Base de datos (MySQL compartido de /opt/shared, red net-shared) ─────────
DB_ROOT_PASSWORD=__PASSWORD_DEL_MYSQL_COMPARTIDO__

# api (dominio)
DB_HOST=mysql_db
DB_PORT=3306
DB_USER=root
DB_NAME=FICHADA
DB_DIALECT=mysql
API_PORT=80

# auth
DB_HOST_AUTH=mysql_db
DB_PORT_AUTH=3306
DB_USER_AUTH=root
DB_ROOT_PASSWORD_AUTH=__PASSWORD_DEL_MYSQL_COMPARTIDO__
DB_NAME_AUTH=FICHADA_AUTH
DB_DIALECT_AUTH=mysql
AUTH_PORT=80

# mailer (NO usa base de datos: ENABLE_EMAIL_LOG=false → no conecta a MySQL)
MAILER_PORT=80

# ─── JWT + Basic Auth servicio↔servicio ──────────────────────────────────────
SECRET_KEY=__SECRET_FUERTE_COMPARTIDO__
AUTH_BASIC_USER=auth
AUTH_BASIC_PW=__BASIC_PW__
MAILER_BASIC_USER=mailer
MAILER_BASIC_PW=__BASIC_PW__

# ─── URLs inter-servicio (hostnames de net-shared) + branding ────────────────
AUTH_API_URL=http://fichada_auth
MAILER_API_URL=http://fichada_mailer
APP_NAME=Fichada
WEB_URL=https://panel.fichada.sda.ovh

# ─── Seed admin (lo crea `node db/seed.js`; debe existir en auth por su migración 007) ──
ADMIN_EMAIL=admin@fichada.com
ADMIN_PASSWORD=__CAMBIAR__
ADMIN_NOMBRE=Administrador
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=Fichada

# ─── SMTP del mailer (para que las invitaciones se envíen de verdad) ─────────
MAILER_USER=__smtp_user__
MAILER_PASSWORD=__smtp_password__
MAILER_SMTP_HOST=smtp.gmail.com
MAILER_SMTP_PORT=587
MAILER_SMTP_SECURE=false
MAILER_FROM_NAME=Fichada
MAILER_FROM_EMAIL=noreply@fichada.sda.ovh

# Google Maps (backoffice: mapa de fichadas). Maps JavaScript API del proyecto GCP.
GOOGLE_MAPS_API_KEY=
