# Copiá este archivo como .env.deploy.test y completá con los valores REALES.
# Los .env.deploy.<env> reales NO se versionan (ver .gitignore).

# ─── Destino SSH del server ──────────────────────────────────────────────────
DEPLOY_USER=deploy-user
DEPLOY_SERVER=your.server.host
DEPLOY_PORT=22
DEPLOY_PATH=/opt/test/fichada
DEPLOY_SSH_KEY=~/.ssh/id_ed25519

# ─── Imagen / registro (GHCR) ────────────────────────────────────────────────
DEPLOY_TAG=TEST
GITHUB_REGISTRY_USER=your-github-user
# El PAT con write:packages suele venir del entorno (~/.bashrc → export GITHUB_REGISTRY_TOKEN=...).
# Si no, descomentá y completá acá (NUNCA lo commitees):
# GITHUB_REGISTRY_TOKEN=

# ─── Post-deploy ─────────────────────────────────────────────────────────────
# "true" para correr el seed (admin + ajustes) después del up. Default false.
DEPLOY_RUN_SEED=false
