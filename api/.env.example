# ─── Servidor ──────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=80

# ─── Base de datos (MySQL compartido de /opt/shared, en net-shared) ─────────
DB_HOST=mysql_db
DB_PORT=3306
DB_USER=root
# Lo completa `make env` leyendo /opt/shared/.env (no se commitea el secreto).
DB_ROOT_PASSWORD=CHANGEME
DB_NAME=FICHADA
DB_DIALECT=mysql

# ─── JWT (compartido con el servicio auth, HS256) ──────────────────────────
SECRET_KEY=supersecret

# ─── Servicios core ────────────────────────────────────────────────────────
AUTH_API_URL=http://fichada_auth
MAILER_API_URL=http://fichada_mailer

# Basic Auth servicio↔servicio (para que el seed/invitación consulten a auth)
AUTH_BASIC_USER=auth
AUTH_BASIC_PW=secret
# Basic Auth del mailer (su user es distinto al de auth)
MAILER_BASIC_USER=mailer
MAILER_BASIC_PW=secret

# ─── Seed admin (debe existir en auth, seedeado por su migración 007) ───────
ADMIN_EMAIL=admin@fichada.com
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=Fichada

# ─── Frontend ──────────────────────────────────────────────────────────────
WEB_URL=http://localhost:3000
